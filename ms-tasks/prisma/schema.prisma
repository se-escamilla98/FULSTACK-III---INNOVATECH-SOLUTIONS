generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

model Task {
  id          String     @id @default(uuid())
  name        String
  description String?
  area        String
  status      TaskStatus @default(PENDING)
  assignedTo  String     // employeeId del encargado
  teamId      String
  projectId   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  logs        TaskLog[]
}

// Bitácora de cambios y comentarios por tarea
model TaskLog {
  id         String   @id @default(uuid())
  taskId     String
  employeeId String   // quien dejó el comentario
  authorName String   // nombre para mostrar sin consultar ms-teams
  comment    String
  createdAt  DateTime @default(now())
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}
