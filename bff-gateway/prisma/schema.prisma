generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("BFF_DATABASE_URL")
}

enum UserRole {
  admin
  developer
  reader
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique  // RUT del empleado como username
  passwordHash String
  displayName  String            // nombre completo del empleado
  role         UserRole @default(developer)
  employeeId   String?           // UUID del empleado en ms-teams
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
