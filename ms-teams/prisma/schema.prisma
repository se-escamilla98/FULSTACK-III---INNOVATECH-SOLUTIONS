generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TeamStatus {
  ACTIVE
  INACTIVE
}

model Employee {
  id        String   @id @default(uuid())
  name      String
  rut       String   @unique
  position  String
  createdAt DateTime @default(now())
}

model Team {
  id          String     @id @default(uuid())
  name        String
  description String
  status      TeamStatus @default(ACTIVE)
  leaderId    String
  area        String
  members     Member[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Member {
  id         String   @id @default(uuid())
  employeeId String
  name       String
  role       String
  teamId     String
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}