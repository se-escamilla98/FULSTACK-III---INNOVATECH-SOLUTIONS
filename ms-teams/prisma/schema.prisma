
generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TeamStatus {
  ACTIVE
  INACTIVE
}
model Team {
  id          String   @id @default(uuid())
  name        String
  description String
  status      TeamStatus   @default(ACTIVE)	
  leaderId    String   @default(uuid())
  area	      String
  integrantes String[]	
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}